# Copie para .env na VPS e preencha com segredos novos.
# Nao reutilize JWT, service role, senha Postgres ou volumes do network-hub legado.

COMPOSE_PROJECT_NAME=bradox-revenda

APP_DOMAIN=bradox-revenda.seudominio.com
API_DOMAIN=api.bradox-revenda.seudominio.com
SITE_URL=https://bradox-revenda.seudominio.com
API_EXTERNAL_URL=https://api.bradox-revenda.seudominio.com
ADDITIONAL_REDIRECT_URLS=https://bradox-revenda.seudominio.com

POSTGRES_DB=bradox_revenda
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque_esta_senha_postgres
POSTGRES_PORT=5432
PGRST_DB_SCHEMAS=bradox_revenda,storage

JWT_SECRET=gere_um_jwt_secret_hex_ou_base64_novo
ANON_KEY=gere_anon_key_com_o_jwt_secret_novo
SERVICE_ROLE_KEY=gere_service_role_key_com_o_jwt_secret_novo
SECRET_KEY_BASE=gere_secret_key_base_novo
JWT_EXPIRY=3600

DISABLE_SIGNUP=false
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_PHONE_AUTOCONFIRM=false

SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Bradox Revenda

VITE_BRADOX_SUPABASE_URL=https://api.bradox-revenda.seudominio.com
VITE_BRADOX_SUPABASE_ANON_KEY=gere_anon_key_com_o_jwt_secret_novo
VITE_BRADOX_SUPABASE_SCHEMA=bradox_revenda